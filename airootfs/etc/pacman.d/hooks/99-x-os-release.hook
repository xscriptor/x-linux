[Trigger]
Operation = Install
Operation = Upgrade
Type = Package
Target = filesystem

[Action]
Description = Reescribiendo identidad x en os-release...
When = PostTransaction
# Usamos printf para escribir el archivo completo de cero. Es más seguro.
Exec = /bin/sh -c "printf 'NAME=\"X\"\nPRETTY_NAME=\"X\"\nID=x\nID_LIKE=arch\nBUILD_ID=rolling\nANSI_COLOR=\"0;36\"\nHOME_URL=\"https://dev.xscriptor.com/x\"\nDOCUMENTATION_URL=\"https://dev.xscriptor.com/x/docs\"\nSUPPORT_URL=\"https://dev.xscriptor.com/x/support\"\nBUG_REPORT_URL=\"https://github.com/xscriptor/x\"\nLOGO=x\n' > /etc/os-release"